# Local-only. Never commit a populated .env.

# Where Gallery Sort keeps its DB, thumbnails, trash, and logs.
# Default: ~/.gallery-sort
GALLERY_SORT_HOME=

# SQLite database location. If unset, derived from GALLERY_SORT_HOME.
# Prisma resolves "file:" URLs relative to prisma/schema.prisma's directory.
DATABASE_URL="file:./dev.db"

# AI sidecar (Python FastAPI) — bind address. ALWAYS loopback.
AI_SIDECAR_URL="http://127.0.0.1:7860"

# Shared secret used by the Node backend to call the sidecar.
# Generated on first launch if blank. Treat as a per-machine secret.
AI_SIDECAR_TOKEN=

# Log level: fatal | error | warn | info | debug | trace
LOG_LEVEL="info"

# Worker concurrency caps
WORKER_HASH_CONCURRENCY=4
WORKER_THUMB_CONCURRENCY=2
WORKER_AI_CONCURRENCY=1

# Trash retention in days (0 disables automatic prompts)
TRASH_RETENTION_DAYS=30

# Telemetry — OFF by default. Set to "1" to opt in. Aggregated counts only.
TELEMETRY_OPT_IN=0
