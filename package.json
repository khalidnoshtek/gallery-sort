{
  "name": "gallery-sort",
  "version": "0.1.0",
  "private": true,
  "description": "Privacy-first, local-first AI photo manager for chaotic 10k-100k+ libraries.",
  "scripts": {
    "dev": "concurrently -n next,ai -c blue,green \"pnpm dev:next\" \"pnpm ai:dev\"",
    "dev:next": "next dev --turbo",
    "ai:dev": "cd services/ai && (test -d .venv || python3 -m venv .venv) && .venv/bin/pip install -q -r requirements.txt && .venv/bin/uvicorn main:app --host 127.0.0.1 --port 7860 --reload",
    "ai:setup": "cd services/ai && python3 -m venv .venv && .venv/bin/pip install -r requirements.txt",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:smoke",
    "test:smoke": "tsx --test tests/smoke.test.ts",
    "db:setup": "prisma generate && prisma db push --skip-generate",
    "db:push": "prisma db push --skip-generate",
    "db:studio": "prisma studio",
    "db:reset": "prisma db push --force-reset --skip-generate",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@tanstack/react-virtual": "^3.11.2",
    "better-sqlite3": "^11.7.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exiftool-vendored": "^28.5.0",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.469.0",
    "next": "^15.1.4",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "piscina": "^4.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.5",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "ulid": "^2.3.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.4",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
